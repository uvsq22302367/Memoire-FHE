{
	"name": "LaTeX Codespace",
	"image": "sanjibsen/weblatex:latest",
	"remoteUser": "root",
	"customizations": {
		"vscode": {
			"extensions": [
				"james-yu.latex-workshop",
                "valentjn.vscode-ltex"
			],
			"settings": {
				"latex-workshop.latex.autoBuild.run": "onFileChange",
				"latex-workshop.view.pdf.viewer": "tab"
			}
		}
	}
}
